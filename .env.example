# Public data/config paths
TW_PUBLIC_DATA_DIR=examples/sample_data
TW_PUBLIC_CONFIG_DIR=examples/sample_config
TW_PROPHET_MODELS_DIR=models
TW_PROPHET_LOG_DIR=logs

# Optional file overrides
TW_SAMPLE_SHIPMENTS_CSV=examples/sample_data/shipments.csv
TW_SAMPLE_INVENTORY_CSV=examples/sample_data/inventory.csv
TW_SAMPLE_PARTS_CSV=examples/sample_data/parts.csv
TW_EXCLUDED_JSON=examples/sample_config/sample_excluded_products.json
TW_WEEKLY_JSON=examples/sample_config/sample_weekly_data_list.json

# Web server
TW_WEB_HOST=0.0.0.0
PORT=8000

# Email (disabled by default)
TW_ENABLE_EMAIL=0
TW_SMTP_HOST=
TW_SMTP_PORT=587
TW_SMTP_USER=
TW_SMTP_PASS=
TW_SMTP_FROM=

