# TW_Prophet 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env は git 追跡対象外です（.gitignore 参照）。

# ------------------------------------------------------------------
# 動作モード: internal（MDB/MySQL使用）または sample（サンプルCSV使用）
# ------------------------------------------------------------------
TW_DATA_MODE=internal

# ------------------------------------------------------------------
# Web サーバー設定
# ------------------------------------------------------------------
PORT=8000
TW_WEB_HOST=0.0.0.0

# ------------------------------------------------------------------
# データ保存先（省略時: %ProgramData%\TW_Prophet\data）
# ------------------------------------------------------------------
# TW_PROPHET_DATA_DIR=C:\ProgramData\TW_Prophet\data
# TW_PROPHET_MODELS_DIR=C:\ProgramData\TW_Prophet\data\models
# TW_PROPHET_LOG_DIR=C:\ProgramData\TW_Prophet\data\logs
# TW_PROPHET_CONFIG_DIR=C:\ProgramData\TW_Prophet\data\config

# ------------------------------------------------------------------
# MDB パス（internal モード時。省略時は TW_MDB_BASE_DIR + ファイル名）
# ------------------------------------------------------------------
# TW_MDB_BASE_DIR=\\File-server\データベース
# TW_SHIPMENT_MDB=\\File-server\データベース\簡易受注管理.mdb
# TW_POST_SHIPMENT_MDB=\\File-server\データベース\出荷管理.mdb
# TW_MANUFACTURE_MDB=\\File-server\データベース\製造管理.mdb

# ------------------------------------------------------------------
# MySQL 接続（internal モード + MySQL 連携時のみ必要）
# ------------------------------------------------------------------
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=
# MYSQL_TABLE_STOCK=stock

# ------------------------------------------------------------------
# PHP ブリッジ用 - TW_Prophet モジュールの場所
# ------------------------------------------------------------------
# TW_PROPHET_PATH=\\File-server\データベース\TW_Prophet

# ------------------------------------------------------------------
# Web 学習・通知設定
# ------------------------------------------------------------------
TW_PROPHET_ALLOW_WEB_TRAIN=0
TW_PROPHET_NOTIFY_AUTO=1
TW_PROPHET_NOTIFY_INTERVAL_MIN=360

# ------------------------------------------------------------------
# メール通知（SMTP）
# ------------------------------------------------------------------
TW_ENABLE_EMAIL=0
# TW_SMTP_HOST=smtp.example.com
# TW_SMTP_PORT=587
# TW_SMTP_USER=
# TW_SMTP_PASS=
# TW_SMTP_FROM=noreply@example.com

# ------------------------------------------------------------------
# サンプル CSV パス（sample モード時）
# ------------------------------------------------------------------
# TW_SAMPLE_DATA_DIR=examples/sample_data
# TW_SAMPLE_CONFIG_DIR=examples/sample_config
# TW_SAMPLE_SHIPMENTS_CSV=examples/sample_data/shipments.csv
# TW_SAMPLE_INVENTORY_CSV=examples/sample_data/inventory.csv
# TW_SAMPLE_PARTS_CSV=examples/sample_data/parts.csv

# ------------------------------------------------------------------
# 高度な設定
# ------------------------------------------------------------------
# TW_PROPHET_ENABLE_CUSTOMER_FEATURES=0
