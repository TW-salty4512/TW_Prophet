# Python cache
__pycache__/
*.py[cod]
*.pyo

# Virtual env
.venv/
venv/
env/

# Runtime outputs (generated at runtime, not source)
models/
logs/
*.pkl
*.log
evaluation_results_*.csv

# ----------------------------------------------------------------
# 機密・個人情報・ローカル固有の設定ファイル（追跡対象外）
# ----------------------------------------------------------------
# 環境変数 / シークレット
.env
.env.*
!.env.example

# DB 接続情報（例: mysql_config.example.json は追跡対象）
mysql_config.json
# 社内専用インストーラ用の実認証情報ファイル（絶対にコミットしない）
mysql_config.internal.json
# 社内専用インストーラ成果物（社内配布のみ・GitHub Release には上げない）
installer/Output/TW_Prophet_Internal_*.exe

# アプリ設定（例: settings.example.json は追跡対象）
settings.json

# 通知状態（ランタイム状態）
notify_state.json

# 運用時に書き換えるランタイム JSON（テンプレートは examples/ に置く）
email_list.json
excluded_products.json
notify_settings.json
weekly_data_list.json

# ローカル開発用バッチ（個人パスが入る可能性）
*.local.bat
*.local.ps1

# 個人パス(prefix)を含む conda バックアップ（environment.yml に置き換え済み）
Prophet_backup.yml

# ----------------------------------------------------------------
# PyInstaller / インストーラビルド成果物（再現可能なため追跡不要）
# ----------------------------------------------------------------
installer/build/
installer/dist/
installer/Output/

# ----------------------------------------------------------------
# OS / エディタ
# ----------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
*.swp
*.swo
